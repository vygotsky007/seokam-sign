# 석암 전자서명 (seokam-sign) 환경변수
# Railway / 로컬 .env 에 채워주세요. 키가 없으면 로컬 파일 저장소(.localstore)로 폴백합니다.

# 공유 Supabase 프로젝트: fyxskyrzkjbfzlhfukbg
SUPABASE_URL=https://fyxskyrzkjbfzlhfukbg.supabase.co

# 서비스 롤 키 (서버 전용 - 업로드/쓰기). 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# anon 키 (현재 1단계에선 미사용이지만 규칙상 함께 둠)
SUPABASE_KEY=

# 포트 (Railway가 자동 주입. 로컬은 비우면 3500 사용)
PORT=
