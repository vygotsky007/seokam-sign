# 석암 전자서명 (seokam-sign) 환경변수
# Railway / 로컬 .env 에 채워주세요. 키가 없으면 로컬 파일 저장소(.localstore)로 폴백합니다.

# 공유 Supabase 프로젝트: fyxskyrzkjbfzlhfukbg
SUPABASE_URL=https://fyxskyrzkjbfzlhfukbg.supabase.co

# 서비스 롤 키 (서버 전용 - 업로드/쓰기). 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# anon 키 (현재 1단계에선 미사용이지만 규칙상 함께 둠)
SUPABASE_KEY=

# 포트 (Railway가 자동 주입. 로컬은 비우면 3500 사용)
PORT=

# ── 관리 화면 보호 (PIN 게이트) ──────────────────────────
# 편집기(/)·링크 발급·제출 현황·다운로드/ZIP 등 모든 관리 기능을 PIN으로 보호합니다.
# 학부모 작성 페이지(/f/토큰)만 공개입니다.
# 해시 생성:  npm run hash -- "원하는PIN"   → 출력된 SIGN_ADMIN_HASH 값을 여기에 붙여넣기.
SIGN_ADMIN_HASH=

# (선택) 세션 쿠키 서명 시크릿. 비우면 해시에서 파생(안정). 여러 인스턴스면 고정 권장.
SIGN_SESSION_SECRET=

# (레거시/폴백) 평문 PIN. SIGN_ADMIN_HASH 가 없을 때만 사용. 가급적 해시를 쓰세요.
# ADMIN_PIN=
# ※ 위 둘 다 비어 있으면 게이트가 비활성화되어 관리 화면이 공개됩니다(로컬 개발용).
